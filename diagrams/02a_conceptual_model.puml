@startuml Konceptualni model - WMS Elektronicke soucastky
hide circle

class Soucastka {
  - id : int
  - nazev : String
  - popis : String
  - partNumber : String
  --
  + upravitUdaje()
  + zobrazInformace()
}

class KategorieSoucastky {
  - id : int
  - nazev : String
  - popis : String
}

class Dodavatel {
  - id : int
  - nazev : String
  - email : String
  - telefon : String
  --
  + upravitKontakt()
}

class Sklad {
  - id : int
  - nazev : String
  - adresa : String
  --
  + pridatLokaci()
  + odebratLokaci()
}

class SkladovaLokace {
  - id : int
  - kodLokace : String
  - popis : String
  --
  + pridatSoucastku()
  + odebratSoucastku()
}

class PohybSkladu {
  - id : int
  - datum : Date
  - mnozstvi : int
  --
  + provestPohyb()
}

class Naskladneni {
  --
  + provestNaskladneni()
}

class Vyskladneni {
  --
  + provestVyskladneni()
}

class Presun {
  --
  + provestPresun()
}

class Projekt {
  - id : int
  - nazev : String
  - popis : String
  --
  + pridatSoucastku()
  + odebratSoucastku()
  + zobrazitSoucastky()
}

class ProjektSoucastka {
  - mnozstvi : int
  - poznamka : String
}

' Vztahy
KategorieSoucastky "1" -- "0..*" Soucastka
Dodavatel "1" -- "0..*" Soucastka

Sklad "1" -- "0..*" SkladovaLokace

SkladovaLokace "1" -- "0..*" PohybSkladu
Soucastka "1" -- "0..*" PohybSkladu

PohybSkladu <|-- Naskladneni
PohybSkladu <|-- Vyskladneni
PohybSkladu <|-- Presun

Projekt "1" -- "0..*" ProjektSoucastka
Soucastka "1" -- "0..*" ProjektSoucastka

@enduml
