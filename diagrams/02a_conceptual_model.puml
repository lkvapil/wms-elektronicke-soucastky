@startuml Konceptualni model - WMS Elektronicke soucastky
hide circle

class Soucastka {
  id : int
  nazev : String
  popis : String
  partNumber : String
  +upravitUdaje()
  +zobrazInformace()
}

class KategorieSoucastky {
  id : int
  nazev : String
  popis : String
}

class Dodavatel {
  id : int
  nazev : String
  email : String
  telefon : String
  +upravitKontakt()
}

class Sklad {
  id : int
  nazev : String
  adresa : String
  +pridatLokaci()
  +odebratLokaci()
}

class SkladovaLokace {
  id : int
  kodLokace : String
  popis : String
}

class PohybSkladu {
  id : int
  datum : Date
  mnozstvi : int
  +provestPohyb()
}

class Naskladneni {
  cisloDodavky : String
  +provestNaskladneni()
}

class Vyskladneni {
  duvod : String
  +provestVyskladneni()
}

class Presun {
  zdrojovaLokace : String
  cilovaLokace : String
  +provestPresun()
}

class Projekt {
  id : int
  nazev : String
  popis : String
  +pridatSoucastku()
  +odebratSoucastku()
  +zobrazitSoucastky()
}

class ProjektSoucastka {
  mnozstvi : int
  poznamka : String
}

' ===== vztahy =====

KategorieSoucastky "1" -- "0..*" Soucastka : kategorizuje
Dodavatel "1" -- "0..*" Soucastka : dodava

Sklad "1" *-- "0..*" SkladovaLokace : obsahuje

SkladovaLokace "1" -- "0..*" Soucastka : [kodLokace]

Soucastka "1" -- "0..*" PohybSkladu : pohyb
SkladovaLokace "1" -- "0..*" PohybSkladu : misto

PohybSkladu <|-- Naskladneni
PohybSkladu <|-- Vyskladneni
PohybSkladu <|-- Presun

Projekt "1" -- "0..*" ProjektSoucastka : obsahuje
Soucastka "1" -- "0..*" ProjektSoucastka : jePouzitaV

@enduml
