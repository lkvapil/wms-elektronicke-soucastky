@startuml
top to bottom direction
skinparam CircledCharacterRadius 0
skinparam CircledCharacterFontSize 0
skinparam defaultFontSize 14
skinparam classFontSize 15
skinparam classFontStyle bold
skinparam ArrowFontSize 14
skinparam ArrowFontStyle bold
skinparam linetype ortho
skinparam nodesep 142
skinparam ranksep 100

class Uzivatel {
  id: int
  jmeno: String
  email: String
  vytvoritPohyb()
  spravovatSoucastky()
  priraditSoucastkuProjektu()
}

class Projekt {
  id: int
  nazev: String
  priradSoucastku(s: Soucastka)
  odeberSoucastku(s: Soucastka)
}

class Soucastka {
  id: int
  nazev: String
  mnozstvi: int
  zvysMnozstvi(pocet: int)
  snizMnozstvi(pocet: int)
  overDostupnost(): boolean
}

abstract class SkladovyPohyb {
  id: int
  datum: Date
  stav: String
  provestPohyb()
}

class PrijemPohyb {
  dodavatel: String
  vytvoritPohyb()
}

class VydejPohyb {
  duvod: String
  vytvoritPohyb()
}

class PresunutiPohyb {
  zdrojLokaceId: int
  cilLokaceId: int
  zmenLokaci()
}

class Sklad {
  id: int
  nazev: String
}

class Lokace {
  id: int
  oznaceni: String
}

' generalizace
PrijemPohyb --|> SkladovyPohyb
VydejPohyb --|> SkladovyPohyb
PresunutiPohyb --|> SkladovyPohyb

' kvalifikovana vazba
Sklad "[id: int]" --> "1" Soucastka : najdiSoucastku

' datove vztahy
Projekt "1" --> "*" Soucastka : obsahuje
SkladovyPohyb "*" --> "1" Soucastka : je součástí
Sklad "1" --> "*" Lokace : obsahuje
Lokace "1" --> "*" Soucastka : ukládá
SkladovyPohyb --> Sklad : mění stav

' uzivatel
Uzivatel --> SkladovyPohyb : vytváří
Uzivatel --> Projekt : spravuje

' layout - vlevo SkladovyPohyb/Sklad/Lokace, vpravo Uzivatel/Projekt/Soucastka
PrijemPohyb -[hidden]right- VydejPohyb
VydejPohyb -[hidden]right- PresunutiPohyb
SkladovyPohyb -[hidden]down- Sklad
Sklad -[hidden]down- Lokace
VydejPohyb -[hidden]down- Uzivatel
Uzivatel -[hidden]down- Projekt
Projekt -[hidden]down- Soucastka

@enduml
