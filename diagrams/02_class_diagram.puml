@startuml
title Class diagram - WMS
top to bottom direction
skinparam linetype ortho

class Projekt {
  -id: int
  -nazev: String
  +priradSoucastku(s: Soucastka)
  +odeberSoucastku(s: Soucastka)
}

class Soucastka {
  -id: int
  -nazev: String
  -mnozstvi: int
  +zvysMnozstvi(pocet: int)
  +snizMnozstvi(pocet: int)
}

class Pohyb {
  -id: int
  -typ: String
  -datum: Date
  +vytvoritPohyb()
  +schvalit()
  +provestPohyb()
}

' vertikalni vazby (A4 optimalizace)
Projekt --> Soucastka : obsahuje
Soucastka --> Pohyb : vytvari

@enduml
