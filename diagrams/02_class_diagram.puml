@startuml
title Class diagram - WMS
top to bottom direction
skinparam linetype ortho

class Projekt {
  -id: int
  -nazev: String

  +priradSoucastku(s: Soucastka)
  +odeberSoucastku(s: Soucastka)
}

class Soucastka {
  -id: int
  -nazev: String
  -mnozstvi: int

  +zvysMnozstvi(pocet: int)
  +snizMnozstvi(pocet: int)
}

class Pohyb {
  -id: int
  -typ: String
  -datum: Date
  -stav: String

  +vytvoritPohyb()
  +schvalit()
  +provestPohyb()
}

class Sklad {
  -id: int
  -nazev: String
}

class Lokace {
  -id: int
  -oznaceni: String
}

' vztahy (logicky dolu)
Sklad "1" --> "*" Lokace
Lokace "1" --> "*" Soucastka

Soucastka "1" --> "*" Pohyb : vytvari
Projekt "1" --> "*" Soucastka : obsahuje

@enduml
