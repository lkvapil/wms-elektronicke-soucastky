@startuml
title Class diagram - WMS

class Soucastka {
  -id: int
  -nazev: String
  -mnozstvi: int
  +zvysMnozstvi(pocet: int)
  +snizMnozstvi(pocet: int)
}

class Projekt {
  -id: int
  -nazev: String
  +priradSoucastku(s: Soucastka)
  +odeberSoucastku(s: Soucastka)
}

class Pohyb {
  -id: int
  -typ: String
  -datum: Date
  +vytvoritPohyb()
  +schvalit()
  +provestPohyb()
}

Soucastka "1" --> "*" Pohyb : vytvari
Projekt "1" --> "*" Soucastka : obsahuje

@enduml
