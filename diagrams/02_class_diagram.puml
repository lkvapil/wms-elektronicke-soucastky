@startuml
top to bottom direction
skinparam CircledCharacterRadius 0
skinparam CircledCharacterFontSize 0
skinparam defaultFontSize 14
skinparam classFontSize 15
skinparam classFontStyle bold
skinparam ArrowFontSize 14
skinparam ArrowFontStyle bold
skinparam linetype ortho
skinparam nodesep 142
skinparam ranksep 100

class Uzivatel {
  id: int
  jmeno: String
  email: String
  vytvoritPohyb()
  spravovatSoucastky()
  priraditSoucastkuProjektu()
}

class Projekt {
  id: int
  nazev: String
  priradSoucastku(s: Soucastka)
  odeberSoucastku(s: Soucastka)
}

class Soucastka {
  id: int
  nazev: String
  mnozstvi: int
  zvysMnozstvi(pocet: int)
  snizMnozstvi(pocet: int)
  overDostupnost(): boolean
}

abstract class Pohyb {
  id: int
  datum: Date
  stav: String
  schvalit()
  provestPohyb()
}

class PrijemPohyb {
  dodavatel: String
  vytvoritPohyb()
}

class VydejPohyb {
  duvod: String
  vytvoritPohyb()
}

class Sklad {
  id: int
  nazev: String
  aktualizujMnozstvi()
}

class Lokace {
  id: int
  oznaceni: String
}

' generalizace
PrijemPohyb --|> Pohyb
VydejPohyb --|> Pohyb

' kvalifikovana vazba
Sklad "[id: int]" --> "1" Soucastka : najdiSoucastku

' datove vztahy
Projekt "1" --> "*" Soucastka : obsahuje
Soucastka "1" --> "*" Pohyb : je součástí
Sklad "1" --> "*" Lokace : obsahuje
Lokace "1" --> "*" Soucastka : ukládá
Pohyb --> Sklad : mění stav

' uzivatel
Uzivatel --> Pohyb : vytváří
Uzivatel --> Projekt : spravuje

' layout jako u kolegy - Pohyb nahore, Soucastka dole
PrijemPohyb -[hidden]right- VydejPohyb
PrijemPohyb -[hidden]down- Pohyb
Uzivatel -[hidden]right- Pohyb
Pohyb -[hidden]down- Sklad
Uzivatel -[hidden]down- Projekt
Projekt -[hidden]right- Sklad
Sklad -[hidden]down- Lokace
Lokace -[hidden]down- Soucastka

@enduml
