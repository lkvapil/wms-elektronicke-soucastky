@startuml
title Class diagram - WMS
top to bottom direction
skinparam CircledCharacterRadius 0
skinparam CircledCharacterFontSize 0
skinparam defaultFontSize 11
skinparam linetype ortho
skinparam nodesep 60
skinparam ranksep 50

class Uzivatel {
  vytvoritPohyb()
  spravovatSoucastky()
  priraditSoucastkuProjektu()
}

class Projekt {
  id: int
  nazev: String
  priradSoucastku(s: Soucastka)
  odeberSoucastku(s: Soucastka)
}

class Soucastka {
  id: int
  nazev: String
  mnozstvi: int
  zvysMnozstvi(pocet: int)
  snizMnozstvi(pocet: int)
  overDostupnost(): boolean
}

abstract class Pohyb {
  id: int
  datum: Date
  stav: String
  schvalit()
  provestPohyb()
}

class PrijemPohyb {
  dodavatel: String
  vytvoritPohyb()
}

class VydejPohyb {
  duvod: String
  vytvoritPohyb()
}

class Sklad {
  id: int
  nazev: String
  aktualizujMnozstvi()
}

class Lokace {
  id: int
  oznaceni: String
}

' generalizace
PrijemPohyb --|> Pohyb
VydejPohyb --|> Pohyb

' kvalifikovana vazba
Sklad "[id: int]" --> "1" Soucastka : najdiSoucastku

' datove vztahy
Projekt "1" --> "*" Soucastka : obsahuje
Soucastka "1" --> "*" Pohyb : je součástí
Sklad "1" --> "*" Lokace : obsahuje
Lokace "1" --> "*" Soucastka : ukládá
Pohyb --> Sklad : mění stav

' uzivatel
Uzivatel --> Pohyb : vytváří
Uzivatel --> Soucastka : spravuje
Uzivatel --> Projekt : spravuje
Uzivatel --> Sklad : spravuje

' layout
Uzivatel -[hidden]right- Projekt
Projekt -[hidden]right- Soucastka
Soucastka -[hidden]right- Sklad
Soucastka -[hidden]down- Pohyb
PrijemPohyb -[hidden]right- VydejPohyb
Pohyb -[hidden]down- PrijemPohyb
Sklad -[hidden]down- Lokace

@enduml
