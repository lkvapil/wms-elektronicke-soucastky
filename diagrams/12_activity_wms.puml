@startuml

start

:Uživatel zadá data pohybu\n(typ, součástka, množství);

:vytvoritPohyb()\n-- inicializuje pohyb, přiřadí ID, datum, typ;

:overitData()\n-- ověří existenci součástky,\ndostatečné množství, platnost lokací;

if (Data OK?) then (ano)

  if (Typ == příjem?) then (ano)
    :soucastka.zvysMnozstvi(pocet);
  elseif (Typ == výdej?) then (ano)
    :soucastka.snizMnozstvi(pocet);
  else (přesun)
    :zmenLokaci();
  endif

  :Pohyb potvrzen;

else (ne)
  :Pohyb zamítnut\n-- uložena chyba;
endif

stop

@enduml
